# Optional default number for test calls. Use E.164 when possible, e.g. +17045551212.
GV_DEFAULT_CALL_TO=

# Browser backend: playwright or firefox. Use firefox for an already-authenticated Firefox profile.
GV_BACKEND=playwright

# Browser profile directory. Keep this private because it stores the logged-in Google session.
GV_PROFILE_DIR=.voice-profile

# Optional browser executable. Usually auto-detected from .browsers/ after npm run setup.
GV_BROWSER_PATH=

# Firefox profile to reuse. Leave blank to auto-detect a default Firefox profile when possible.
GV_FIREFOX_PROFILE=

# Optional Firefox executable. Snap Firefox is usually:
# /snap/firefox/current/usr/lib/firefox/firefox
GV_FIREFOX_BINARY=

# Set to 1 to run Chromium headless. Login and live calling normally need the visible browser.
GV_HEADLESS=0

# Optional delay after call/answer actions so the browser does not close immediately.
GV_KEEP_OPEN_MS=0

# Delay after dialing before playing TTS, giving the human time to answer.
GV_SPEAK_DELAY_MS=10000

# Default spoken text for speak-call.
GV_SAY_TEXT=Hello. The Google Voice call audio bridge is working.

# TTS provider and voice. Kokoro keeps synthesis local when its model files are installed.
GV_TTS_PROVIDER=kokoro
GV_TTS_VOICE=en-US-AndrewNeural
GV_TTS_RATE=+0%
GV_TTS_PITCH=+0Hz
GV_TTS_VOLUME=+0%

# Free local neural TTS alternative. Requires kokoro-onnx and models/kokoro files.
# Set GV_TTS_PROVIDER=kokoro to use it.
GV_KOKORO_VOICE=am_echo
GV_KOKORO_SPEED=1.0
GV_KOKORO_VOLUME=0.75

# Virtual audio sink used to feed TTS into the browser microphone.
GV_AUDIO_SINK=gv_tts
GV_AUDIO_LOOPS=0

# Virtual speaker sink used to capture call audio coming out of Firefox.
GV_SPEAKER_SINK=gv_speaker
GV_VOSK_MODEL=models/vosk-model-small-en-us-0.15
GV_STT_PROVIDER=whisper
GV_WHISPER_MODEL=base.en
GV_LISTEN_SECONDS=14
GV_LISTEN_DELAY_MS=4500

# Conversation defaults. GV_CONVERSATION_TURNS=0 means keep going until a stop phrase,
# max duration, or repeated silence instead of ending after a tiny test loop.
GV_CONVERSATION_TURNS=0
GV_CONVERSATION_MAX_MINUTES=30
GV_CONVERSATION_SILENCE_LIMIT=3
GV_CONVERSATION_REPLY_COMMAND=
GV_CONVERSATION_REPLY_TIMEOUT_MS=75000
